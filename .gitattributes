# デフォルト: テキストファイルは LF で統一
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf
*.ipynb text eol=lf

# Web / Config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Docs
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Shell
*.sh text eol=lf

# Databricks
*.dbc binary
*.dbx text eol=lf

# バイナリ: 変換しない
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.zip binary
*.gz binary
*.tar binary
*.whl binary
*.exe binary
*.dll binary
*.pkl binary
*.parquet binary
*.delta binary
*.pdf binary
